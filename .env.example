# =============================================
# LISCONVASTAG AVIATOR SIGNALS - ENV CONFIG
# =============================================
# Copy this file to .env.local and fill in values

# ---- AUTH ----
# Secret key for signing JWT tokens (generate with: openssl rand -base64 32)
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_STRING_32_CHARS

# ---- ADMIN AUTH ----
# Admin password for the admin panel
ADMIN_PASSWORD=admin123

# ---- CLIENT ACCESS KEYS ----
# Comma-separated access keys for client login
# Format: key:siteUrl,key:siteUrl OR just keys (any key works for any site)
CLIENT_ACCESS_KEYS=SIGNAL2024,AVIATOR01,LISCKEY99

# ---- OPENAI ----
# Get your key from: https://platform.openai.com/api-keys
# Leave blank to disable AI features (app still works without it)
OPENAI_API_KEY=

# ---- APP MODE ----
# Set to 'live' when live connectors are ready. Default: 'mock'
DEFAULT_DATA_MODE=mock

# ---- APP URL (for Vercel deployment) ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
